{
  "cli_default_open_behavior": "new_window",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "base_keymap": "VSCode",
  "minimap": {
    "show": "always"
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "file_types": {
    "twig": [
      "*.twig"
    ],
    "html": [
      "*.html.twig"
    ]
  },
  "linked_edits": true,
  "show_whitespaces": "all",
  "tab_size": 4,
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    }
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark",
  },
  "project_panel": {
    "dock": "left"
  }
}
